rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow connectivity check
    match /test/connection {
      allow read: if true;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validations ---

    function isValidProduct(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'price', 'stock']) &&
             data.keys().size() <= 20 && 
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.price is number &&
             data.stock is number;
    }

    function isValidCustomer(data) {
      return data.keys().hasAll(['id', 'ownerId', 'name', 'balance']) &&
             data.keys().size() <= 20 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() > 0 &&
             data.balance is number;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['id', 'ownerId', 'type', 'amount', 'createdAt']) &&
             data.keys().size() <= 25 &&
             data.ownerId == request.auth.uid &&
             data.type in ['sale', 'payment', 'credit', 'payment_received', 'credit_given', 'return'] &&
             data.amount is number &&
             data.createdAt is string;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['ownerId', 'name']) &&
             data.keys().size() <= 25 &&
             data.ownerId == request.auth.uid &&
             data.name is string;
    }

    function isValidExpense(data) {
      return data.keys().hasAll(['id', 'ownerId', 'amount', 'description', 'createdAt']) &&
             data.keys().size() <= 15 &&
             data.ownerId == request.auth.uid &&
             data.amount is number &&
             data.description is string &&
             data.createdAt is string;
    }

    // --- Matches ---

    match /products/{productId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isSignedIn() && isValidId(productId) && isValidProduct(incoming()) && 
                       incoming().ownerId == existing().ownerId &&
                       incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /customers/{customerId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(customerId) && isValidCustomer(incoming());
      allow update: if isSignedIn() && isValidId(customerId) && isValidCustomer(incoming()) && 
                       incoming().ownerId == existing().ownerId &&
                       incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming());
      allow update: if isSignedIn() && isValidId(transactionId) && isValidTransaction(incoming()) && 
                       incoming().ownerId == existing().ownerId &&
                       incoming().id == existing().id &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['isDeleted', 'deletedAt']);
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /expenses/{expenseId} {
      allow get: if isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid);
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(expenseId) && isValidExpense(incoming());
      allow update: if isSignedIn() && isValidId(expenseId) && isValidExpense(incoming()) && 
                       incoming().ownerId == existing().ownerId &&
                       incoming().id == existing().id;
      allow delete: if isSignedIn() && existing().ownerId == request.auth.uid;
    }

    match /settings/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow write: if isSignedIn() && userId == request.auth.uid && isValidSettings(incoming());
    }
  }
}
